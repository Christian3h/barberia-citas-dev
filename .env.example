# Variables de entorno para el sistema de agendamiento
# Copiar este archivo a .env.local y completar los valores

# Google Sheets
# ID del spreadsheet (extraer de la URL de Google Sheets)
VITE_GOOGLE_SPREADSHEET_ID=tu_spreadsheet_id_aqui

# API Key de Google (para lectura pública)
VITE_GOOGLE_API_KEY=tu_api_key_aqui

# Wulshis Backend URL
VITE_WULSHIS_URL=http://localhost:3001
